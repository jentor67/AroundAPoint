# Compiler and flags
FC = gfortran
FFLAGS = -std=f2008 -O2 -Wall

# Executable name
TARGET = my_program

# Source files (auto-detect all .f90)
#SRCS := $(wildcard *.f90)
SRCS = constantsmodule.f90 startparametersmodule.f90 vectormodule.f90 gravitymodule.f90 main.f90 

#print-sources:
#	@echo "Sources: $(SRCS)"

# Object files corresponding to source files
OBJS := $(SRCS:.f90=.o)

# Dependency files (for modules)
DEPS := $(SRCS:.f90=.d)

# Default target
all: $(TARGET)

# Link object files
#$(TARGET): $(OBJS)
#	$(FC) $(FFLAGS) -o $@ $(OBJS)
$(TARGET): $(OBJS)
	$(FC) $(FFLAGS) -o $@ $(filter-out main.o,$(OBJS)) main.o

# Compile .f90 to .o and generate dependency file
%.o: %.f90
	$(FC) $(FFLAGS) -cpp $< -o $@ -J . -MMD -MF $(<:.f90=.d)

# Include dependency files if they exist
-include $(DEPS)

# Clean build
clean:
	rm -f $(OBJS) $(TARGET) $(DEPS) *.mod

.PHONY: all clean
