#!/usr/bin/bash
# Compiler and flags
FC=gfortran
FFLAGS=-std=f2008 -Wall -Wextra

# Target executable name
TARGET=program

# Source files (list all your .f90 files here)
SRC=(
  constantsModule
  vectorModule
  startParametersModule
  gravityModule
  aroundAPoint
)


# Object files (automatically generated from SRC)
OBJ = $(SRC:.f95=.o)

# Default rule
all: $(TARGET)

# Link step
$(TARGET): $(OBJ)
	$(FC) $(OBJ) -o $(TARGET)

# Compile step
%.o: %.f95
	$(FC) $(FFLAGS) -c $< -o $@

# Clean build files
clean:
	rm -f $(OBJ) $(TARGET) *.mod
