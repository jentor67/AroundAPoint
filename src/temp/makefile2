# Define the compiler
FC = gfortran

# Define compilation flags (Modern Fortran 2008 standard)
# -g: Includes debugging information
# -O2: General optimization
FCFLAGS = -std=f2008 -g -O2

# Name of the final executable
TARGET = my_program

# List of source files (e.g., main.f90, module1.f90)
SRCS = main.f90 constantsmodule.f90 startparametersmodule.f90 vectormodule.f90 gravitymodule.f90

# Generate object file names from source file names
OBJS = $(SRCS:.f90=.o)

# Default rule: build the executable
all: $(TARGET)

# Rule to link object files into the final executable
$(TARGET): $(OBJS)
	$(FC) $(FCFLAGS) -o $@ $^

# Pattern rule to compile .f90 files into .o object files
%.o: %.f90
	$(FC) $(FCFLAGS) -c $<

# Clean up build artifacts (object files, module files, and executable)
clean:
	rm -f $(OBJS) *.mod $(TARGET)

.PHONY: all clean

