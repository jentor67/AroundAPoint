# Compiler and flags
FC = gfortran
FFLAGS = -std=f2008 -O2 -Wall

# Executable name
TARGET = my_program

# Recursively find all .f90 files
SRCS := $(shell find . -name "*.f90")

# Object files corresponding to source files
OBJS := $(SRCS:.f90=.o)

# Dependency files for modules
DEPS := $(SRCS:.f90=.d)

# Default target
all: $(TARGET)

# Linking: main.o linked last to avoid undefined reference
$(TARGET): $(OBJS)
	$(FC) $(FFLAGS) -o $@ $(filter-out main.o,$(OBJS)) main.o

# Compile .f90 to .o and generate dependency file for modules
%.o: %.f90
	$(FC) $(FFLAGS) -cpp $< -o $@ -J . -MMD -MF $(<:.f90=.d)

# Include generated dependency files if they exist
-include $(DEPS)

# Clean build
clean:
	rm -f $(OBJS) $(TARGET) $(DEPS) *.mod

.PHONY: all clean
